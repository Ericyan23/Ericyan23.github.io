---
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import "../styles/tokens.css";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const baseTitle = "Sihan Yan";
const {
  title = baseTitle,
  description = "Sihan Yan's personal website for data science, machine learning, NLP, analytics, data systems, projects, research notes, and writing.",
  image = "/images/profile.jpeg",
  noindex = false
} = Astro.props;

const pageTitle = title === baseTitle ? `${baseTitle} - Data Science, ML, and NLP` : `${title} | ${baseTitle}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://ericyan23.github.io");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, canonical).toString()} />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <SiteHeader />
    <main id="content">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
