---
const links = [
  { href: "/", label: "Home" },
  { href: "/about/", label: "About" },
  { href: "/projects/", label: "Projects" },
  { href: "/research/", label: "Research" },
  { href: "/cv/", label: "CV" },
  { href: "/contact/", label: "Contact" }
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  const normalized = href.replace(/\/$/, "") || "/";
  return normalized === "/" ? currentPath === "/" : currentPath.startsWith(normalized);
};
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href="/" aria-label="Sihan Yan home">
      <span class="brand-mark">SY</span>
      <span>Sihan Yan</span>
    </a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      {links.map((link) => <a href={link.href} aria-current={isActive(link.href) ? "page" : undefined}>{link.label}</a>)}
    </nav>

    <details class="mobile-nav">
      <summary>Menu</summary>
      <nav aria-label="Mobile navigation">
        {links.map((link) => <a href={link.href} aria-current={isActive(link.href) ? "page" : undefined}>{link.label}</a>)}
      </nav>
    </details>
  </div>
</header>
