---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Timeline from "../components/Timeline.astro";
import SkillGroup from "../components/SkillGroup.astro";
import { profile } from "../data/profile";
import { skillGroups } from "../data/skills";

const cvProjectOrder = ["news-source-classification", "hoopsiq", "flight-delay-risk-segmentation"];
const projects = (await getCollection("projects"))
  .filter((project) => cvProjectOrder.includes(project.id))
  .sort((a, b) => cvProjectOrder.indexOf(a.id) - cvProjectOrder.indexOf(b.id));
const cvHighlights = [
  "UPenn MSE-DS student, expected 2026, with 3.8/4.0 GPA.",
  "Normalized Penn EENT alumni engagement data into an 11-table 3NF schema across 6,833 contacts and 15,971 enrollment rows.",
  "Built Tableau, Databricks, SQL, and Salesforce workflows for marketing, donation, and engagement analytics.",
  "Built analytics projects across NLP classification, NBA performance data, and marketing channel regression."
];
const analyticsEvidence = [
  "CRM and alumni data normalization across Penn SIS, HubSpot, Airtable, Qualtrics, and relationship-documented database tables.",
  "Marketing analytics work across Google Grants, StackAdapt, Google Ads, Facebook, Bing, Google Analytics, and Salesforce donation data.",
  "Applied modeling with regression diagnostics, churn and retention modeling, SMOTE, ROC/AUC, BERT embeddings, and SQL-backed dashboards."
];
---

<BaseLayout title="CV" description="HTML CV for Sihan Yan.">
  <section class="page-shell detail-hero">
    <p class="eyebrow">CV</p>
    <h1>Sihan Yan</h1>
    <p class="lede">{profile.shortTitle}. {profile.title}.</p>
    <div class="cv-contact-line" aria-label="CV contact information">
      <a href={`mailto:${profile.email}`}>{profile.email}</a>
      <span>{profile.location}</span>
      <a href={profile.links.github} target="_blank" rel="noreferrer">GitHub</a>
      <a href={profile.links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
    </div>
    <ul class="cv-proof-list">
      {cvHighlights.map((highlight) => <li>{highlight}</li>)}
    </ul>
    <div class="button-row">
      {profile.cvPdfAvailable && <a class="button primary" href="/cv.pdf" download>Download PDF</a>}
      <a class="button secondary" href={`mailto:${profile.email}`}>Email me</a>
      <a class="button secondary" href="/projects/">Selected projects</a>
    </div>
  </section>

  <section class="page-shell two-column">
    <div class="section-header">
      <p class="eyebrow">Profile</p>
      <h2>Data analyst positioning</h2>
      <p>{profile.currentGoal} My strongest evidence is in cleaning messy CRM and operational data, designing relational data structures, building repeatable SQL and Databricks workflows, and translating analytics into reporting that supports outreach, budgeting, and retention decisions.</p>
    </div>
    <div class="resume-panel">
      <h3>Focus areas</h3>
      <ul>
        {profile.interests.map((interest) => <li>{interest}</li>)}
      </ul>
    </div>
  </section>

  <section class="page-shell two-column">
    <div class="section-header">
      <p class="eyebrow">Analytics evidence</p>
      <h2>Work I can discuss in detail</h2>
      <p>The PDF version emphasizes database normalization, BI reporting, SQL ETL, marketing analytics, and applied modeling from recent work and projects.</p>
    </div>
    <div class="resume-panel">
      <h3>Evidence</h3>
      <ul>
        {analyticsEvidence.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="page-shell two-column">
    <div class="section-header">
      <p class="eyebrow">Education</p>
      <h2>Education</h2>
    </div>
    <Timeline items={profile.education} />
  </section>

  <section class="page-shell">
    <div class="section-header">
      <p class="eyebrow">Selected projects</p>
      <h2>Evidence of applied work</h2>
    </div>
    <div class="resume-project-list">
      {
        projects.map((project) => (
          <article>
            <div class="resume-project-heading">
              <h3><a href={`/projects/${project.id}/`}>{project.data.title}</a></h3>
              <span>{project.data.time}</span>
            </div>
            <p>{project.data.summary}</p>
            <ul>
              {project.data.highlights.slice(0, 2).map((highlight) => <li>{highlight}</li>)}
            </ul>
            <p class="note">{project.data.tech.join(", ")}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="page-shell">
    <div class="section-header">
      <p class="eyebrow">Skills</p>
      <h2>Technical skills</h2>
    </div>
    <div class="skill-grid compact">
      {skillGroups.map((group) => <SkillGroup title={group.title} items={group.items} />)}
    </div>
  </section>
</BaseLayout>
