---
import { getCollection, render } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";

export async function getStaticPaths() {
  const notes = await getCollection("reading", ({ data }) => !data.draft);
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note }
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
const paperMeta = [
  note.data.paperTitle,
  note.data.authors.length > 0 ? note.data.authors.join(", ") : undefined,
  note.data.venue,
  note.data.year
].filter(Boolean).join(" / ");
---

<ContentLayout
  title={note.data.title}
  description={note.data.summary}
  date={note.data.date}
  tags={note.data.tags}
  backHref="/reading/"
  backLabel="Back to reading"
>
  <p><strong>Paper:</strong> {paperMeta}</p>
  {note.data.link && <p><a href={note.data.link} target="_blank" rel="noreferrer">External paper link</a></p>}
  <Content />
</ContentLayout>
